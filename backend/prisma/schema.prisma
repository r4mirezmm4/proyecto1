generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  refreshToken String?  @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Deck {
  id                  Int            @id @default(autoincrement())
  name                String
  description         String?
  type                String
  sourceLanguage      String?
  targetLanguage      String?
  directionMode       String         @default("normal") @map("direction_mode")
  similarityThreshold Float          @default(0.7) @map("similarity_threshold")
  cards               Card[]
  sessions            StudySession[]
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@map("decks")
}

model Card {
  id             Int      @id @default(autoincrement())
  deckId         Int      @map("deck_id")
  deck           Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  term           String
  definition     String
  timesCorrect   Int      @default(0) @map("times_correct")
  timesWrong     Int      @default(0) @map("times_wrong")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("cards")
}

model StudySession {
  id           Int      @id @default(autoincrement())
  deckId       Int      @map("deck_id")
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  direction    String
  totalCards   Int      @map("total_cards")
  correctCards Int      @map("correct_cards")
  wrongCards   Int      @map("wrong_cards")
  completedAt  DateTime @default(now()) @map("completed_at")

  @@map("study_sessions")
}